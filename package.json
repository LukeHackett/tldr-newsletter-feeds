{
  "name": "tldr-newsletter-feeds",
  "version": "1.0.0",
  "description": "Fetches TLDR RSS feeds, enriches them with full page content, and outputs RSS, Atom and JSON files",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "clean": "rm -rf docs",
    "lint": "eslint src/",
    "dev": "GITHUB_PAGES_URL=http://localhost:3000 node src/index.js",
    "test": "node --test --experimental-test-module-mocks tests/*.test.js",
    "serve": "serve docs -p 3000",
    "build": "node src/index.js"
  },
  "dependencies": {
    "axios": "1.16.0",
    "cheerio": "1.0.0",
    "fast-xml-parser": "5.7.2",
    "feed": "5.1.0"
  },
  "devDependencies": {
    "eslint": "9.26.0",
    "serve": "14.2.4"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24"
  }
}
